{
  "name": "@dozyio/libp2p-pcp",
  "version": "1.0.1",
  "description": "libp2p NAT traversal service backed by PCP",
  "license": "Apache-2.0 OR MIT",
  "homepage": "https://github.com/dozyio/js-libp2p-pcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dozyio/js-libp2p-pcp.git"
  },
  "bugs": {
    "url": "https://github.com/dozyio/js-libp2p-pcp/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "libp2p",
    "nat",
    "pcp",
    "rfc6887",
    "ipv6"
  ],
  "type": "module",
  "types": "./dist/src/index.d.ts",
  "files": [
    "src",
    "dist",
    "!dist/test",
    "!**/*.tsbuildinfo"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      [
        "@semantic-release/commit-analyzer",
        {
          "preset": "conventionalcommits",
          "releaseRules": [
            {
              "breaking": true,
              "release": "major"
            },
            {
              "revert": true,
              "release": "patch"
            },
            {
              "type": "feat",
              "release": "minor"
            },
            {
              "type": "fix",
              "release": "patch"
            },
            {
              "type": "docs",
              "release": "patch"
            },
            {
              "type": "chore",
              "release": "patch"
            },
            {
              "type": "test",
              "release": "patch"
            },
            {
              "type": "deps",
              "release": "patch"
            },
            {
              "scope": "no-release",
              "release": false
            }
          ]
        }
      ],
      [
        "@semantic-release/release-notes-generator",
        {
          "preset": "conventionalcommits",
          "presetConfig": {
            "types": [
              {
                "type": "feat",
                "section": "Features"
              },
              {
                "type": "fix",
                "section": "Bug Fixes"
              },
              {
                "type": "chore",
                "section": "Trivial Changes"
              },
              {
                "type": "docs",
                "section": "Documentation"
              },
              {
                "type": "deps",
                "section": "Dependencies"
              },
              {
                "type": "test",
                "section": "Tests"
              }
            ]
          }
        }
      ],
      "@semantic-release/changelog",
      "@semantic-release/npm",
      "@semantic-release/github",
      [
        "@semantic-release/git",
        {
          "assets": [
            "CHANGELOG.md",
            "package.json"
          ]
        }
      ]
    ]
  },
  "scripts": {
    "clean": "aegir clean",
    "lint": "aegir lint",
    "dep-check": "aegir dep-check",
    "doc-check": "aegir doc-check",
    "build": "aegir build --no-bundle",
    "prepack": "npm run build",
    "docs": "aegir docs",
    "release": "aegir release",
    "test": "aegir test -t node",
    "test:node": "aegir test -t node"
  },
  "dependencies": {
    "@dozyio/pcp": "^1.0.2",
    "@libp2p/interface": "^3.1.0",
    "@libp2p/interface-internal": "^3.0.10",
    "@libp2p/utils": "^7.0.10",
    "@multiformats/multiaddr": "^13.0.1",
    "@multiformats/multiaddr-matcher": "^3.0.1",
    "main-event": "^1.0.1"
  },
  "devDependencies": {
    "@libp2p/crypto": "^5.1.13",
    "@libp2p/logger": "^6.2.2",
    "@libp2p/peer-id": "^6.0.4",
    "aegir": "^47.0.22",
    "sinon-ts": "^2.0.0"
  },
  "sideEffects": false
}
